{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MiSTer Companion Hub Categories",
  "type": "object",
  "required": [
    "schema_version",
    "categories"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "sort_order"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "scripts",
              "cores",
              "extras",
              "roms",
              "wallpaper_packs"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "sort_order": {
            "type": "integer"
          },
          "hide_when_empty": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
